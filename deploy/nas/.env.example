# Copy to deploy/nas/.env on the NAS and fill in real values. DO NOT commit the real .env.
# Values mirror what currently lives in ~/.claude-mem/.env on the Mac.

# FalkorDB auth (must match the value clients/server use).
FALKORDB_PASSWORD=replace-with-real-password

# Bearer token for the HTTP API (Authorization: Bearer <token> on every request).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
KG_HUB_API_TOKEN=replace-with-real-token

# LLM backend for entity extraction during ingest (百炼 Anthropic-compatible endpoint).
ANTHROPIC_AUTH_TOKEN=replace-with-real-token
ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/...   # same as Mac's .env
ANTHROPIC_MODEL=qwen3.6-plus
